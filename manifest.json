{
  "manifest_version": 3,
  "name": "Browser Sticky Notes Pro – Lightweight Notes, Export, Styling & More",
  "version": "7.5",
  "description": "Opens a Sticky note on the Page when invoked using Shift+ALT+N.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "notifications",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "side_panel": {
    "default_path": "popup.html"
  },

  "background": {
    "service_worker": "assets/scripts/background.js"
  },
  "options_page": "options.html",
  "commands": {
    "open_popup": {
      "suggested_key": {
        "default": "Shift+Alt+N"
      },
      "description": "Opens the popup"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/scripts/content.js"],
      "css": ["assets/styles/content_style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}